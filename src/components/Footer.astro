<footer class="footer" role="contentinfo">
  <div class="footer-main">
    <div class="footer-container">
      <div class="footer-brand">
        <img src="/logo.png" alt="Pixán Cocina del Alma" class="footer-logo" />
        <p class="footer-tagline">Una cocina sin fronteras,<br />diseñada para alimentar cuerpo y alma.</p>
        <div class="footer-redes">
          <a href="https://www.facebook.com/pixancocinadelalma" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="footer-social-link" id="footer-fb">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
