            </svg>
          </a>
        </div>
      </div>

      <div class="footer-nav">
        <h4 class="footer-nav-title">Navegación</h4>
        <ul>
          <li><a href="#inicio">Inicio</a></li>
          <li><a href="#concepto">Concepto</a></li>
          <li><a href="#menu">Menú</a></li>
          <li><a href="#galeria">Galería</a></li>
          <li><a href="#historia">Historia</a></li>
          <li><a href="#contacto">Contacto</a></li>
        </ul>
      </div>

      <div class="footer-info">
        <h4 class="footer-nav-title">Información</h4>
        <div class="footer-detail">
          <span>📍</span>
          <address>Manuel A. Romero esq. Ángel Suárez #102<br />Paraíso, Tabasco, México</address>
        </div>
        <div class="footer-detail">
          <span>📞</span>
          <a href="tel:+529336886903">933 688 6903</a>
        </div>
        <div class="footer-detail">
          <span>🕐</span>
          <span>Lun — Dom: 07:00 — 23:00</span>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p class="footer-copy">
      © {new Date().getFullYear()} Pixán Cocina del Alma · Paraíso, Tabasco, México
    </p>
    <p class="footer-maya">
      <em>Pixán</em> — del maya <em>píischan</em>, "alma"
    </p>
  </div>
</footer>

<style>
  .footer { background: #040000; border-top: 1px solid rgba(192,20,28,0.2); }
  .footer-main { padding: 4rem 2rem; }
  .footer-container {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 3rem;
  }
  .footer-logo { height: 72px; width: auto; object-fit: contain; margin-bottom: 1.2rem; display: block; }
  .footer-tagline {
    font-family: var(--font-heading);
    font-size: 0.92rem; font-style: italic;
    color: rgba(232,221,208,0.55); line-height: 1.7; margin-bottom: 1.5rem;
  }
  .footer-redes { display: flex; gap: 0.75rem; }
  .footer-social-link {
    width: 38px; height: 38px; border-radius: 50%;
    background: rgba(192,20,28,0.1); border: 1px solid rgba(192,20,28,0.2);
    display: flex; align-items: center; justify-content: center;
    color: rgba(232,221,208,0.6);
    text-decoration: none; transition: all 0.3s ease;
  }
  .footer-social-link:hover {
    background: rgba(192,20,28,0.25); border-color: #c0141c; color: #e8ddd0;
    transform: translateY(-2px);
  }
  .footer-nav-title {
    font-family: var(--font-heading);
    font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: #c0141c; margin-bottom: 1.2rem;
  }
  .footer-nav ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .footer-nav a {
    color: rgba(232,221,208,0.55); text-decoration: none; font-size: 0.9rem;
    transition: color 0.3s;
  }
  .footer-nav a:hover { color: #e8ddd0; }
  .footer-info { display: flex; flex-direction: column; gap: 0.9rem; }
  .footer-detail { display: flex; gap: 0.7rem; align-items: flex-start; font-size: 0.85rem; }
  .footer-detail span:first-child { flex-shrink: 0; }
  .footer-detail address { font-style: normal; color: rgba(232,221,208,0.55); line-height: 1.6; }
  .footer-detail a { color: rgba(232,221,208,0.55); text-decoration: none; transition: color 0.3s; }
  .footer-detail a:hover { color: #c0141c; }
  .footer-detail span:last-child { color: rgba(232,221,208,0.55); }
  .footer-bottom {
    border-top: 1px solid rgba(192,20,28,0.1);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1100px;
    margin: 0 auto;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .footer-copy { font-size: 0.75rem; color: rgba(232,221,208,0.3); margin: 0; }
  .footer-maya {
    font-family: var(--font-heading);
    font-size: 0.78rem; color: rgba(192,20,28,0.4); margin: 0;
  }
  @media (max-width: 900px) {
    .footer-container { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / 3; }
  }
  @media (max-width: 580px) {
    .footer-container { grid-template-columns: 1fr; }
    .footer-brand { grid-column: auto; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
