---
---
<section class="contacto" id="contacto" aria-label="Contacto e información">
  <div class="contacto-container">
    <div class="section-header" data-animate>
      <span class="section-eyebrow">Visítanos</span>
      <h2 class="section-title">Contáctanos</h2>
      <div class="title-ornament"><span></span><span class="diamond">◆</span><span></span></div>
    </div>

    <div class="contacto-grid" data-animate>
      <!-- INFO CARDS -->
      <div class="info-panel">
        <div class="info-card" id="info-horario">
          <div class="info-icon" aria-hidden="true">🕐</div>
          <div class="info-content">
            <h3>Horarios</h3>
            <p class="horario-main">Lun — Dom · 07:00 — 23:00</p>
            <ul class="horario-list">
              <li><span class="hl-label">☀ Desayunos</span><span class="hl-time">07:00 — 13:00</span></li>
              <li><span class="hl-label">🕯 Comidas & Cenas</span><span class="hl-time">13:00 — 23:00</span></li>
            </ul>
          </div>
        </div>

        <div class="info-card" id="info-telefono">
          <div class="info-icon" aria-hidden="true">📞</div>
          <div class="info-content">
            <h3>Teléfono</h3>
            <a href="tel:+529336886903" class="contact-link" id="tel-link">933 688 6903</a>
            <p class="contact-note">Solo llamadas</p>
          </div>
        </div>

        <div class="info-card" id="info-direccion">
          <div class="info-icon" aria-hidden="true">📍</div>
          <div class="info-content">
            <h3>Dirección</h3>
            <address class="address-text">
              Manuel A. Romero esquina Ángel Suárez #102<br />
              Paraíso, Tabasco, México
            </address>
            <a
              href="https://maps.app.goo.gl/EdHD5y82RsMBd9ff6"
              target="_blank"
              rel="noopener noreferrer"
              class="map-btn"
              id="map-btn"
            >
              Ver en Google Maps →
            </a>
          </div>
        </div>

        <!-- REDES SOCIALES -->
        <div class="redes-card" id="info-redes">
          <h3 class="redes-title">Redes Sociales</h3>
          <div class="redes-links">
            <a
              href="https://www.facebook.com/pixancocinadelalma"
              target="_blank"
              rel="noopener noreferrer"
              class="red-link"
              id="facebook-link"
              aria-label="Facebook de Pixán Cocina del Alma"
            >
              <span class="red-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </span>
              <span>Pixán cocina del alma</span>
            </a>
            <a
              href="https://www.instagram.com/pixancocina"
              target="_blank"
              rel="noopener noreferrer"
              class="red-link"
              id="instagram-link"
              aria-label="Instagram de Pixán"
            >
              <span class="red-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </span>
              <span>@pixancocina</span>
            </a>
            <a
              href="https://www.tiktok.com/@pixancocina"
              target="_blank"
              rel="noopener noreferrer"
              class="red-link"
              id="tiktok-link"
              aria-label="TikTok de Pixán"
            >
              <span class="red-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                  <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/>
                </svg>
              </span>
              <span>pixancocina</span>
            </a>
          </div>
        </div>
      </div>

      <!-- MAPA Y FOTO -->
      <div class="mapa-slot" id="mapa-slot">
        <div class="mapa-foto">
          <img src="/fotos/restaurante_afuera.jpeg" alt="Fachada del restaurante Pixán" />
        </div>
        <div class="mapa-embed-zone">
          <!-- Reemplaza el contenido de abajo con el iframe de Google Maps real -->
          <!-- Ejemplo: <iframe src="https://www.google.com/maps/embed?pb=..." allowfullscreen loading="lazy"></iframe> -->
          <iframe
            src="https://maps.google.com/maps?width=100%25&amp;height=600&amp;hl=es&amp;q=Manuel%20A.%20Romero%20esquina%20Angel%20Suarez%20%23102%20Paraiso%20Tabasco%20Mexico+(Pixan)&amp;t=&amp;z=16&amp;ie=UTF8&amp;iwloc=B&amp;output=embed"
            title="Ubicación de Pixán Cocina del Alma"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <a
          href="https://maps.app.goo.gl/EdHD5y82RsMBd9ff6"
          target="_blank"
          rel="noopener noreferrer"
          class="mapa-cta"
          id="mapa-cta-btn"
        >
          📍 Abrir en Google Maps
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contacto {
    background: #080000;
    padding: 7rem 2rem;
    position: relative;
  }
  .contacto::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, #c0141c, transparent);
  }
  .contacto-container { max-width: 1100px; margin: 0 auto; }
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .section-header.visible { opacity: 1; transform: translateY(0); }
  .section-eyebrow {
    font-family: var(--font-heading);
    font-size: 0.8rem; letter-spacing: 0.3em; text-transform: uppercase;
    color: #c0141c; display: block; margin-bottom: 0.75rem;
  }
  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 300; color: #fff; letter-spacing: 0.04em; margin: 0 0 1rem;
  }
  .title-ornament { display: flex; align-items: center; justify-content: center; gap: 1rem; }
  .title-ornament span { display: block; width: 60px; height: 1px; background: rgba(192,20,28,0.4); }
  .title-ornament .diamond { color: #c0141c; font-size: 0.6rem; }

  .contacto-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.7s ease 0.15s, transform 0.7s ease 0.15s;
  }
  .contacto-grid.visible { opacity: 1; transform: translateY(0); }

  .info-panel { display: flex; flex-direction: column; gap: 1.5rem; }
  .info-card {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
    background: rgba(15,3,3,0.5);
    border: 1px solid rgba(192,20,28,0.12);
    padding: 1.5rem;
    transition: border-color 0.3s;
  }
  .info-card:hover { border-color: rgba(192,20,28,0.35); }
  .info-icon { font-size: 1.5rem; flex-shrink: 0; margin-top: 2px; }
  .info-content h3 {
    font-family: var(--font-heading);
    font-size: 1rem; font-weight: 400;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: #c0141c; margin-bottom: 0.5rem;
  }
  .horario-main { color: #e8ddd0; font-size: 0.95rem; margin-bottom: 0.5rem; font-family: var(--font-heading); font-style: italic; }
  .horario-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.3rem; }
  .horario-list li { display: flex; justify-content: space-between; align-items: center; font-size: 0.85rem; }
  .hl-label { color: rgba(232,221,208,0.65); }
  .hl-time { color: #c0141c; font-family: var(--font-heading); }
  .contact-link {
    font-family: var(--font-heading);
    font-size: 1.5rem; color: #e8ddd0; text-decoration: none;
    letter-spacing: 0.05em; display: block; margin-bottom: 0.2rem;
    transition: color 0.3s;
  }
  .contact-link:hover { color: #c0141c; }
  .contact-note { font-size: 0.75rem; color: rgba(232,221,208,0.45); margin: 0; }
  address { font-style: normal; color: rgba(232,221,208,0.7); font-size: 0.9rem; line-height: 1.6; margin-bottom: 0.75rem; }
  .map-btn {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.8rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: #c0141c; text-decoration: none;
    border-bottom: 1px solid rgba(192,20,28,0.3);
    padding-bottom: 2px;
    transition: border-color 0.3s, color 0.3s;
  }
  .map-btn:hover { border-color: #c0141c; color: #e01a24; }
  .redes-card {
    background: rgba(15,3,3,0.5);
    border: 1px solid rgba(192,20,28,0.12);
    padding: 1.5rem;
    transition: border-color 0.3s;
  }
  .redes-card:hover { border-color: rgba(192,20,28,0.35); }
  .redes-title {
    font-family: var(--font-heading);
    font-size: 1rem; font-weight: 400; letter-spacing: 0.15em; text-transform: uppercase;
    color: #c0141c; margin-bottom: 1rem;
  }
  .redes-links { display: flex; flex-direction: column; gap: 0.75rem; }
  .red-link {
    display: flex; align-items: center; gap: 0.75rem;
    color: rgba(232,221,208,0.7); text-decoration: none; font-size: 0.9rem;
    transition: color 0.3s;
  }
  .red-link:hover { color: #e8ddd0; }
  .red-icon {
    width: 36px; height: 36px; border-radius: 50%;
    background: rgba(192,20,28,0.12); border: 1px solid rgba(192,20,28,0.25);
    display: flex; align-items: center; justify-content: center;
    color: #c0141c; flex-shrink: 0;
    transition: background 0.3s;
  }
  .red-link:hover .red-icon { background: rgba(192,20,28,0.25); }

  .mapa-slot {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .mapa-foto {
    width: 100%;
    height: 250px;
    border: 1px solid rgba(192,20,28,0.2);
    overflow: hidden;
  }
  
  .mapa-foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mapa-embed-zone {
    flex: 1;
    min-height: 400px;
    border: 1px solid rgba(192,20,28,0.2);
    overflow: hidden;
    background: rgba(10,0,0,0.6);
  }
  .mapa-embed-zone iframe {
    width: 100%; height: 100%; min-height: 400px; border: none; display: block;
    filter: grayscale(80%) contrast(1.1) brightness(0.8);
    transition: filter 0.4s ease;
  }
  .mapa-embed-zone:hover iframe { filter: grayscale(20%) contrast(1.05) brightness(0.9); }
  .mapa-cta {
    display: block;
    text-align: center;
    background: #c0141c;
    color: #fff;
    text-decoration: none;
    padding: 1rem;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: background 0.3s;
  }
  .mapa-cta:hover { background: #e01a24; }

  @media (max-width: 900px) {
    .contacto-grid { grid-template-columns: 1fr; }
    .mapa-embed-zone { min-height: 300px; }
  }
</style>
