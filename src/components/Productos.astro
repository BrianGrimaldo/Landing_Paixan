<script>
  function initProductsFilter() {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const productCards = document.querySelectorAll<HTMLElement>('.product-card');

    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        filterButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const filterValue = btn.getAttribute('data-filter');

        // 1. Fade out all visible cards
        productCards.forEach(card => {
          if (!card.classList.contains('hidden')) {
            card.style.opacity = '0';
            card.style.transform = 'scale(0.96)';
          }
        });

        // 2. After fade-out completes, swap cards
        setTimeout(() => {
          productCards.forEach(card => {
            const cardCategory = card.getAttribute('data-category');
            if (cardCategory === filterValue) {
              card.classList.remove('hidden');
              card.style.opacity = '0';
              card.style.transform = 'scale(0.96)';
              // 3. Fade in new cards
              requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                  card.style.opacity = '1';
                  card.style.transform = 'scale(1)';
                });
              });
            } else {
              card.classList.add('hidden');
              card.style.opacity = '';
              card.style.transform = '';
            }
          });
        }, 280);
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initProductsFilter);
</script>

<style>
  .productos-section {
    background-color: var(--color-bg);
    padding: 6rem 2rem;
    position: relative;
    border-top: 1px solid var(--color-border);
  }

  .productos-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .productos-filters {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3.5rem;
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .productos-filters.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .filter-btn {
    background: transparent;
    border: 1px solid rgba(232, 221, 208, 0.2);
    color: var(--color-text-muted);
    padding: 0.75rem 2rem;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.3s ease;
    border-radius: 0;
    text-transform: uppercase;
  }

  .filter-btn:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  .filter-btn.active {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: #ffffff;
  }

  .productos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    min-height: 300px;
    margin-top: 1.5rem;
  }

  .product-card {
    background: rgba(21, 5, 5, 0.4);
    border: 1px solid rgba(192, 20, 28, 0.1);
    overflow: hidden;
    transition: all 0.3s ease, opacity 0.3s ease, transform 0.3s ease;
    display: flex;
    flex-direction: column;
    opacity: 1;
    transform: scale(1);
  }

  .product-card.hidden {
    display: none !important;
  }

  .product-card:hover {
    transform: translateY(-5px);
    border-color: rgba(192, 20, 28, 0.3);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
  }

  .product-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background-color: #120303;
  }

  .product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 65%;
    transition: transform 0.6s ease;
  }

  .product-card:hover .product-img {
    transform: scale(1.08);
  }

  .image-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1f0808 0%, #0d0202 100%);
    border: 1px dashed rgba(192, 20, 28, 0.25);
    margin: 10px;
    border-radius: 4px;
    color: rgba(232, 221, 208, 0.6);
    gap: 0.5rem;
    text-align: center;
    padding: 1rem;
    z-index: 1;
  }

  .image-placeholder span {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  .image-placeholder small {
    font-size: 0.75rem;
    font-family: monospace;
    opacity: 0.7;
    background: rgba(0, 0, 0, 0.3);
    padding: 2px 6px;
    border-radius: 2px;
  }


  .product-name {
    padding: 0.9rem 1.2rem;
    text-align: center;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--color-text);
    border-top: 1px solid rgba(192, 20, 28, 0.15);
    background: rgba(10, 0, 0, 0.4);
  }

  @media (max-width: 992px) {
    .productos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .productos-grid {
      grid-template-columns: 1fr;
    }
    .filter-btn {
      padding: 0.6rem 1.2rem;
      font-size: 0.85rem;
    }
  }
</style>
