---

<section class="galeria" id="galeria" aria-label="Galería fotográfica y videos">
  <div class="galeria-container">
    <!-- FOTOS -->
    <div class="section-header" data-animate>
      <span class="section-eyebrow">Visuales</span>
      <h2 class="section-title">Galería & Videos</h2>
      <div class="title-ornament">
        <span></span><span class="diamond">◆</span><span></span>
      </div>
      <p class="section-subtitle">
        Imágenes y momentos que capturan la esencia de Pixán.
      </p>
    </div>

    <!-- GRID DE FOTOS -->
    <div class="foto-grid" data-animate aria-label="Galería de fotos">
      <div class="foto-slot foto-large" id="foto-1">
        <img
          src="/fotos/foto-1.jpg"
          alt="Pixán Cocina del Alma - Foto Principal"
        />
      </div>
      <div class="foto-slot" id="foto-2">
        <img src="/fotos/foto-2.jpg" alt="Platillo Estrella en Pixán" />
      </div>
      <div class="foto-slot" id="foto-3">
        <img src="/fotos/foto-3.jpg" alt="Ambiente en Pixán" />
      </div>
      <div class="foto-slot" id="foto-4">
        <img src="/fotos/foto-4.jpg" alt="Ingredientes Frescos" />
      </div>
      <div class="foto-slot" id="foto-5">
        <img src="/fotos/foto-5.jpg" alt="Noche en Pixán" />
      </div>
    </div>

    <!-- VIDEOS -->
    <div class="video-section" data-animate>
      <h3 class="video-section-title">Videos</h3>
      <div class="video-grid">
        <!-- Slot Video 1 -->
        <div class="video-slot" id="video-1">
          <video
            src="/videos/pixan.mp4"
            autoplay
            muted
            loop
            playsinline
            controls></video>
        </div>
        <!-- Slot Video 2 -->
        <div class="video-slot" id="video-2">
          <video
            src="/videos/pixan_2.mp4"
            autoplay
            muted
            loop
            playsinline
            controls></video>
        </div>
        <!-- Slot Video 3 -->
        <div class="video-slot" id="video-3">
          <video
            src="/videos/pixan_3.mp4"
            autoplay
            muted
            loop
            playsinline
            controls></video>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .galeria {
    background: #0a0000;
    padding: 7rem 2rem;
    position: relative;
  }
  .galeria::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, #c0141c, transparent);
  }
  .galeria-container {
    max-width: 1100px;
    margin: 0 auto;
  }
  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.7s ease,
      transform 0.7s ease;
  }
  .section-header.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .section-eyebrow {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #c0141c;
    display: block;
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 300;
    color: #fff;
    letter-spacing: 0.04em;
    margin: 0 0 1rem;
  }
  .title-ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .title-ornament span {
    display: block;
    width: 60px;
    height: 1px;
    background: rgba(192, 20, 28, 0.4);
  }
  .title-ornament .diamond {
    color: #c0141c;
    font-size: 0.6rem;
  }
  .section-subtitle {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-style: italic;
    color: rgba(232, 221, 208, 0.6);
  }

  /* FOTO GRID */
  .foto-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: 240px 240px;
    gap: 0.75rem;
    margin-bottom: 4rem;
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.7s ease 0.15s,
      transform 0.7s ease 0.15s;
  }
  .foto-grid.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .foto-slot {
    position: relative;
    overflow: hidden;
    background: rgba(15, 3, 3, 0.6);
    border: 1px solid rgba(192, 20, 28, 0.15);
    transition: border-color 0.3s;
    cursor: pointer;
  }
  .foto-slot:hover {
    border-color: rgba(192, 20, 28, 0.5);
  }
  .foto-large {
    grid-row: 1 / 3;
  }
  .foto-slot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .foto-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 1rem;
    border: 2px dashed rgba(192, 20, 28, 0.15);
    margin: 1rem;
  }
  .foto-placeholder span {
    font-size: 2rem;
    opacity: 0.5;
  }
  .foto-placeholder p {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(232, 221, 208, 0.5);
    margin: 0;
  }
  .foto-placeholder small {
    font-size: 0.65rem;
    color: rgba(192, 20, 28, 0.4);
    text-align: center;
  }
  .foto-placeholder code {
    background: rgba(192, 20, 28, 0.08);
    padding: 0.05rem 0.3rem;
    font-size: 0.65rem;
  }

  /* VIDEO SECTION */
  .video-section {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.7s ease 0.3s,
      transform 0.7s ease 0.3s;
  }
  .video-section.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .video-section-title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 300;
    color: #e8ddd0;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(192, 20, 28, 0.2);
  }
  .video-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .video-slot {
    aspect-ratio: 9/16;
    background: rgba(10, 0, 0, 0.8);
    border: 1px solid rgba(192, 20, 28, 0.2);
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
  }
  .video-slot:hover {
    border-color: rgba(192, 20, 28, 0.5);
  }
  .video-slot iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  .video-slot video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .video-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 1rem;
    border: 2px dashed rgba(192, 20, 28, 0.2);
    margin: 1rem;
  }
  .video-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(192, 20, 28, 0.15);
    border: 1px solid rgba(192, 20, 28, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    color: #c0141c;
    margin-bottom: 0.5rem;
    line-height: 1;
    text-align: center;
    padding-top: 0.1rem;
  }
  .video-placeholder p {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    color: rgba(232, 221, 208, 0.6);
    margin: 0;
    text-align: center;
  }
  .video-placeholder small {
    font-size: 0.65rem;
    color: rgba(192, 20, 28, 0.4);
    text-align: center;
    display: block;
  }
  .video-placeholder code {
    font-size: 0.6rem;
    background: rgba(192, 20, 28, 0.08);
    padding: 0.05rem 0.3rem;
  }

  @media (max-width: 900px) {
    .foto-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 200px 200px 200px;
    }
    .foto-large {
      grid-row: 1;
      grid-column: 1 / 3;
    }
    .video-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
      justify-items: center;
    }
    .video-slot {
      width: 100%;
      max-width: 400px;
    }
  }
  @media (max-width: 580px) {
    .foto-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    .foto-slot {
      aspect-ratio: 4/3;
    }
    .foto-large {
      grid-row: auto;
      grid-column: auto;
    }
  }
</style>
