---
---
<header class="navbar" id="navbar">
  <div class="navbar-container">
    <a href="#inicio" class="navbar-logo" aria-label="Pixán - Inicio">
      <img src="/logo.png" alt="Pixán Cocina del Alma" class="logo-img" />
    </a>
    <nav class="navbar-nav" id="nav-menu" role="navigation" aria-label="Menú principal">
      <ul class="nav-list">
        <li><a href="#inicio" class="nav-link">Inicio</a></li>
        <li><a href="#concepto" class="nav-link">Concepto</a></li>
        <li><a href="#menu" class="nav-link">Menú</a></li>
        <li><a href="#productos" class="nav-link">Productos</a></li>
        <li><a href="#galeria" class="nav-link">Galería</a></li>
        <li><a href="#historia" class="nav-link">Historia</a></li>
        <li><a href="#contacto" class="nav-link">Contacto</a></li>
      </ul>
    </nav>
    <button class="hamburger" id="hamburger-btn" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 0.8rem 2rem;
    transition: background 0.4s ease, box-shadow 0.4s ease;
    background: transparent;
  }
  .navbar.scrolled {
    background: rgba(10, 0, 0, 0.95);
    backdrop-filter: blur(12px);
    box-shadow: 0 2px 30px rgba(180, 20, 20, 0.15);
  }
  .navbar-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo-img {
    height: 56px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 0 8px rgba(180,20,20,0.4));
    transition: transform 0.3s ease, filter 0.3s ease;
  }
  .logo-img:hover {
    transform: scale(1.05);
    filter: drop-shadow(0 0 16px rgba(180,20,20,0.7));
  }
  .nav-list {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-link {
    color: #e8e0d4;
    text-decoration: none;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    position: relative;
    padding-bottom: 4px;
    transition: color 0.3s ease;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: #c0141c;
    transition: width 0.3s ease;
  }
  .nav-link:hover { color: #fff; }
  .nav-link:hover::after { width: 100%; }
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .hamburger span {
    width: 26px;
    height: 2px;
    background: #e8e0d4;
    transition: all 0.3s ease;
    display: block;
  }
  .hamburger.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .hamburger.active span:nth-child(2) { opacity: 0; }
  .hamburger.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }
  @media (max-width: 768px) {
    .hamburger { display: flex; }
    .navbar-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: rgba(8, 0, 0, 0.97);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease;
    }
    .navbar-nav.open { max-height: 400px; border-bottom: 1px solid rgba(192,20,28,0.3); }
    .nav-list { flex-direction: column; gap: 0; padding: 1rem 2rem; }
    .nav-link { display: block; padding: 0.8rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 1rem; }
    .nav-link::after { display: none; }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const hamburger = document.getElementById('hamburger-btn');
  const navMenu = document.getElementById('nav-menu');

  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 50);
  });

  hamburger?.addEventListener('click', () => {
    const isOpen = navMenu?.classList.toggle('open');
    hamburger.classList.toggle('active');
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });

  document.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', () => {
      navMenu?.classList.remove('open');
      hamburger?.classList.remove('active');
      hamburger?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
